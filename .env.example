# Sistema de Iglesia — environment configuration
# Copy this file to .env.local and fill in the real values.
# .env.local is git-ignored and never committed.

# ============================================================
# Supabase (frontend — exposed to browser, safe with RLS)
# ============================================================
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_XXXXXXXX

# ============================================================
# Supabase (server-side — Edge Functions only, NEVER in frontend)
# Configure these via: supabase secrets set KEY=value
# ============================================================
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_DB_PASSWORD=your-postgres-password
# SUPABASE_JWT_SECRET=your-jwt-secret

# ============================================================
# Stripe (Phase 4+ — scaffolded, not active in v1)
# ============================================================
# Frontend (publishable, safe in browser):
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Server-side (Edge Functions only):
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================
# Email (Resend — Edge Functions only)
# ============================================================
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=recibos@casaderestauracion.org

# ============================================================
# App
# ============================================================
# VITE_APP_URL=http://localhost:5173
# VITE_DEFAULT_CHURCH_LOCALE=es
